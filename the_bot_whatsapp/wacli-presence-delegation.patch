+	}
+	state, err := presenceStateFromString(req.Presence)
+	if err != nil {
+		return sendDelegateResponse{}, err
+	}
+	media, err := presenceMediaFromString(req.PresenceMedia)
+	if err != nil {
+		return sendDelegateResponse{}, err
+	}
+	if err := a.WA().SendChatPresence(ctx, toJID, state, media); err != nil {
+		return sendDelegateResponse{}, err
+	}
+	return sendDelegateResponse{OK: true, Sent: true, To: toJID.String()}, nil
+}
