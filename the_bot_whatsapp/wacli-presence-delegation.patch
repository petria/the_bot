+func resolveSelfReplySender(ctx context.Context, a sendTextApp, chat types.JID, replyTo, override string) string {
+	if strings.TrimSpace(override) != "" || strings.TrimSpace(replyTo) == "" || chat.Server != types.GroupServer {
+		return override
+	}
+
+	quoted, err := a.DB().GetMessage(chat.String(), replyTo)
+	if err != nil || !quoted.FromMe {
+		return override
+	}
+
+	linked := strings.TrimSpace(a.WA().LinkedJID())
+	if linked == "" {
+		return override
+	}
+	linkedJID, err := wa.ParseUserOrJID(linked)
+	if err != nil {
+		return override
+	}
+
+	resolved := a.WA().ResolvePNToLID(ctx, linkedJID)
+	if !resolved.IsEmpty() {
+		return resolved.String()
+	}
+	return linkedJID.String()
+}
