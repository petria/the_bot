# Hokan Main Instance Configuration

# Bot Instance ID
HOKAN_BOT_INSTANCE_ID=hokan-main

# Hermes Manager Settings (Main instance)
HERMES_MANAGER_MAIN_BASE_URL=http://ubuntu-server.local:8651
HERMES_MANAGER_DEVELOP_BASE_URL=http://ubuntu-server.local:8652
HERMES_MANAGER_TOKEN=${HERMES_MANAGER_TOKEN:-}

# Docker Compose settings
PUID=1002
PGID=1002
HOKAN_DATA_DIR=/home/hokan/the_bot-main
DOCKER_GID=989

# Image tags
ENGINE_IMAGE_TAG=main
IO_IMAGE_TAG=main
WEB_IMAGE_TAG=main
WHATSAPP_IMAGE_TAG=main
HERMES_MANAGER_IMAGE_TAG=main

# OpenClaw settings
OPENCLAW_EXTERNAL_HOST_IP=192.168.0.55
OPENCLAW_EXTERNAL_BASE_MOUNT=/mnt/hokan

# Hermes Chat Settings (shared)
HERMES_CHAT_BASE_URL=http://ubuntu-server.local:8643
HERMES_CODER_API_KEY=${HERMES_CODER_API_KEY:-}
HERMES_AI_COMMAND_BASE_URL=http://ubuntu-server.local:8645

# Web UI settings
THE_BOT_WEB_PUBLIC_BASE_URL=http://hokan-main.local:8091

# API Keys (set these in your environment)
# HERMES_MANAGER_TOKEN=
# DISCORD_SECRET=
# TELEGRAM_SECRET=
